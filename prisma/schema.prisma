// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Course {
  record_id      String   @id @default(cuid())
  name           String
  product        String
  type           String
  duration       Int
  instructor     String
  level          String
  status         String
  visibility     String
  positions      String
  examType       String
  description    String?
  creator        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Task {
  record_id      String   @id @default(cuid())
  employeeId     String
  project        String
  courseId       String
  progress       Int      @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  result         String?
  dueDate        DateTime
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Employee {
  record_id      String   @id @default(cuid())
  name           String
  department     String
  position       String
  joinDate       DateTime
  organization   String   @default("总部")
  employmentStatus String @default("在职")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Certificate {
  record_id      String   @id @default(cuid())
  employeeId     String
  certificate    String
  obtainedDate   DateTime
  expiryDate     DateTime
  status         String
  retrainReq     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CertificateType {
  record_id      String   @id @default(cuid())
  name           String   @unique
  issuer         String
  validityYears  Int      @default(0)
  retrainReq     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TrainingProject {
  record_id      String   @id @default(cuid())
  name           String
  type           String
  status         String
  format         String
  period         String
  participants   String
  instructors    String
  owner          String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SyncLog {
  id             Int      @id @default(autoincrement())
  tableName      String
  lastSyncAt     DateTime @default(now())
  status         String
  message        String?
  createdAt      DateTime @default(now())
}
