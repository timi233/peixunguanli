// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Course {
  record_id      String   @id @default(cuid())
  课程名称        String
  所属产品        String
  课程类型        String
  课程时长        Int
  导师           String
  课程难度        String
  课程状态        String
  可见性         String
  适用岗位        String
  考核类型        String
  课程介绍        String?
  创建人         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Task {
  record_id      String   @id @default(cuid())
  关联员工        String
  关联培训计划    String
  关联课程        String
  学习进度        Int      @default(0)
  学习开始时间    DateTime?
  学习完成时间    DateTime?
  考核结果        String?
  截止日期        DateTime
  任务状态        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Employee {
  record_id      String   @id @default(cuid())
  姓名           String
  部门           String
  岗位           String
  入职时间        DateTime
  所属组织        String   @default("总部")
  在职状态        String   @default("在职")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Certificate {
  record_id      String   @id @default(cuid())
  关联人员        String
  证书           String
  获得日期        DateTime
  有效期至        DateTime
  证书状态        String
  复训要求        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CertificateType {
  record_id      String   @id @default(cuid())
  证书名称        String   @unique
  发证机构        String
  有效期         Int      @default(0) // 0 表示长期有效
  复训要求        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TrainingProject {
  record_id      String   @id @default(cuid())
  培训项目名称    String
  培训类型        String
  培训状态        String
  培训形式        String
  培训周期        String
  参与对象        String
  导师           String
  负责人         String
  描述           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SyncLog {
  id             Int      @id @default(autoincrement())
  tableName      String
  lastSyncAt     DateTime @default(now())
  status         String   // success, failed
  message        String?
  createdAt      DateTime @default(now())
}
