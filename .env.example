# 飞书多维表格 API 配置
# 在飞书开放平台创建应用后获取 https://open.feishu.cn/

# 应用 ID (App ID)
FEISHU_APP_ID=cli_xxxxxxxxxxxxx

# 应用密钥 (App Secret)
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 多维表格 App Token (从表格 URL 中获取)
FEISHU_APP_TOKEN=FtGvbKCOOapwSnsHO63cvFTrnCd

# 可选：自定义域名（如有）
# NEXT_PUBLIC_APP_URL=http://localhost:33333
